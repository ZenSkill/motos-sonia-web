PORT=3000
SESSION_SECRET=change-this-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$replace-with-a-bcrypt-hash
ADMIN_EMAIL=admin@tudominio.com

# MongoDB Atlas connection URI
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/mototaxi_db?retryWrites=true&w=majority&appName=catalogo-motos

# SMTP para restablecimiento de contraseña (Gmail App Password o SMTP del proveedor)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
FRONTEND_URL=http://localhost:3000
RESET_TOKEN_EXPIRES=3600
JWT_SECRET=change-this-jwt-secret
